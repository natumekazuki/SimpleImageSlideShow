<div class="control-panel" title="Settings">
    <div id="tiled-panel" class="panel-body">
        <div class="row g-2 align-items-center">
            <div>
                <label class="form-label">Delay min (sec): @MinDelaySeconds</label>
                <input type="range" min="0" max="60" value="@MinDelaySeconds" @oninput="MinDelayInput" />
            </div>
            <div>
                <label class="form-label">Delay max (sec): @MaxDelaySeconds</label>
                <input type="range" min="1" max="60" value="@MaxDelaySeconds" @oninput="MaxDelayInput" />
            </div>
            <div>
                <label class="form-label">Background</label>
                <RgbColorPicker Value="@BackgroundColor"
                                ValueChanged="BackgroundColorSelected"
                                AriaLabel="Tiled background color" />
            </div>
            <div>
                <label class="form-label">Clock</label>
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" role="switch" checked="@ShowClock" @onchange="ClockToggleChanged" />
                    <label class="form-check-label">Show clock</label>
                </div>
                @if (ShowClock)
                {
                    <div class="form-check form-switch mt-1">
                        <input class="form-check-input" type="checkbox" role="switch" checked="@AvoidClockOverlap" @onchange="ClockAvoidOverlapChanged" />
                        <label class="form-check-label">Avoid overlap</label>
                    </div>
                    <select class="form-select form-select-sm mt-1" @onchange="ClockCornerChanged">
                        @foreach (var option in ClockCornerChoices)
                        {
                            <option value="@option.Value" selected="@((ClockCorner == option.Value) ? "selected" : null)">@option.Label</option>
                        }
                    </select>
                    <div class="mt-1">
                        <label class="form-label">Scale: @string.Format("{0:P0}", ClockScale)</label>
                        <input type="range" min="50" max="500" step="5" value="@((int)(ClockScale * 100))" @oninput="ClockScaleInput" />
                    </div>
                }
            </div>
            <div>
                <label class="form-label">Columns: @TiledCols (max @Math.Max(ColsMax, TiledCols))</label>
                <input type="range" min="1" max="@Math.Max(ColsMax, TiledCols)" value="@TiledCols" @oninput="ColsInput" />
                <div class="text-muted small">Grid: @Cols x @Rows</div>
            </div>
            <div>
                <label class="form-label">Min scale: @string.Format("{0:P0}", MinScale)</label>
                <input type="range" min="10" max="100" value="@((int)(MinScale*100))" @oninput="MinScaleInput" />
            </div>
            <div>
                <label class="form-label">Max scale: @string.Format("{0:P0}", MaxScale)</label>
                <input type="range" min="10" max="100" value="@((int)(MaxScale*100))" @oninput="MaxScaleInput" />
            </div>
            <div>
                <label class="form-label">Min tile width: @MinTilePx px</label>
                <input type="range" min="64" max="512" value="@MinTilePx" @oninput="MinTileInput" />
            </div>
            <div>
                <label class="form-label">Scale calculate retry: @RandomScaleTries</label>
                <input type="range" min="1" max="500" value="@RandomScaleTries" @oninput="RandomScaleTriesInput" />
            </div>
            <div class="buttons">
                <button class="btn btn-sm btn-outline-secondary" title="Toggle fullscreen" disabled="@IsWindowModeChanging" @onclick="ToggleWindowMode">
                    @(IsFullScreen ? "Windowed View" : "Full Screen")
                </button>
                <button class="btn btn-sm btn-primary" @onclick="SaveAndApply">Save</button>
                <button class="btn btn-sm btn-secondary" @onclick="ChooseAndApplyFolder">Change Folder</button>
                <button class="btn btn-sm btn-danger" @onclick="ExitApp">Exit</button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public uint MinDelaySeconds { get; set; }
    [Parameter] public uint MaxDelaySeconds { get; set; }
    [Parameter] public string BackgroundColor { get; set; } = string.Empty;
    [Parameter] public bool ShowClock { get; set; }
    [Parameter] public bool AvoidClockOverlap { get; set; }
    [Parameter] public string ClockCorner { get; set; } = string.Empty;
    [Parameter] public double ClockScale { get; set; }
    [Parameter] public IReadOnlyList<ClockCornerChoice> ClockCornerChoices { get; set; } = [];
    [Parameter] public int TiledCols { get; set; }
    [Parameter] public int ColsMax { get; set; }
    [Parameter] public int Cols { get; set; }
    [Parameter] public int Rows { get; set; }
    [Parameter] public double MinScale { get; set; }
    [Parameter] public double MaxScale { get; set; }
    [Parameter] public int MinTilePx { get; set; }
    [Parameter] public uint RandomScaleTries { get; set; }
    [Parameter] public bool IsFullScreen { get; set; }
    [Parameter] public bool IsWindowModeChanging { get; set; }

    [Parameter] public EventCallback<ChangeEventArgs> MinDelayInput { get; set; }
    [Parameter] public EventCallback<ChangeEventArgs> MaxDelayInput { get; set; }
    [Parameter] public EventCallback<string> BackgroundColorSelected { get; set; }
    [Parameter] public EventCallback<ChangeEventArgs> ClockToggleChanged { get; set; }
    [Parameter] public EventCallback<ChangeEventArgs> ClockAvoidOverlapChanged { get; set; }
    [Parameter] public EventCallback<ChangeEventArgs> ClockCornerChanged { get; set; }
    [Parameter] public EventCallback<ChangeEventArgs> ClockScaleInput { get; set; }
    [Parameter] public EventCallback<ChangeEventArgs> ColsInput { get; set; }
    [Parameter] public EventCallback<ChangeEventArgs> MinScaleInput { get; set; }
    [Parameter] public EventCallback<ChangeEventArgs> MaxScaleInput { get; set; }
    [Parameter] public EventCallback<ChangeEventArgs> MinTileInput { get; set; }
    [Parameter] public EventCallback<ChangeEventArgs> RandomScaleTriesInput { get; set; }
    [Parameter] public EventCallback ToggleWindowMode { get; set; }
    [Parameter] public EventCallback SaveAndApply { get; set; }
    [Parameter] public EventCallback ChooseAndApplyFolder { get; set; }
    [Parameter] public EventCallback ExitApp { get; set; }
}
