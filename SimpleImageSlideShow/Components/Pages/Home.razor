@page "/"

<div class="control-panel" title="Settings">
    <div class="panel-body">
        <div class="row g-2 align-items-center">
            <div>
                <label class="form-label">Mode</label>
                <div>
                    <button class="btn btn-sm btn-primary" disabled>Slide</button>
                    <button class="btn btn-sm btn-outline-primary ms-1" @onclick='() => SwitchMode("Tiled")'>Tiled</button>
                </div>
            </div>
            <div>
                <label class="form-label">Delay (sec): @DelaySeconds</label>
                <input type="range" min="1" max="@DelayMax" value="@DelaySeconds" @oninput="OnDelayInput" />
            </div>
            <div>
                <label class="form-label">Count: @ImageCount</label>
                <input type="range" min="1" max="@CountMax" value="@ImageCount" @oninput="OnCountInput" />
            </div>
            <div>
                <label class="form-label">Background</label>
                <select class="form-select form-select-sm" value="@BackgroundColor" @onchange="OnBackgroundColorChanged">
                    @foreach (var option in BackgroundColorOptions)
                    {
                        <option value="@option.Value" selected="@((BackgroundColor == option.Value) ? "selected" : null)">@option.Label</option>
                    }
                </select>
            </div>
            <div class="buttons">
                <button class="btn btn-sm btn-outline-secondary" title="Toggle fullscreen" disabled="@IsWindowModeChanging" @onclick="ToggleWindowModeAsync">
                    @(IsFullScreen ? "Windowed View" : "Full Screen")
                </button>
                <button class="btn btn-sm btn-primary" @onclick="SaveAndApplyAsync">Save</button>
                <button class="btn btn-sm btn-secondary" @onclick="ChooseAndApplyFolderAsync">Change Folder</button>
                <button class="btn btn-sm btn-danger" @onclick="ExitApp">Exit</button>
            </div>
        </div>
    </div>
</div>

<div class="slideshow-container" style="@BackgroundStyle">

    @if (this.Slides.Count > 0)
    {
        @foreach (var imageEntity in this.Slides)
        {
            <div class="slide @imageEntity.CssClass" style="@imageEntity.CssVariables animation-duration:@($"{AnimationDelaySeconds}s")">
                <img src="@GetSrc(imageEntity)" alt="Image" class="img-fluid" />
            </div>
        }
    }
</div>
