@page "/tiled"

<div class="control-panel" title="Settings">
    <div id="tiled-panel" class="panel-body">
        <div class="row g-2 align-items-center">
            <div>
                <label class="form-label">Mode</label>
                <div>
                    <button class="btn btn-sm btn-outline-primary me-1" @onclick='() => SwitchMode("Slide")'>Slide</button>
                    <button class="btn btn-sm btn-primary" disabled>Tiled</button>
                </div>
            </div>
            <div>
                <label class="form-label">Delay (sec): @DelaySeconds</label>
                <input type="range" min="1" max="60" value="@DelaySeconds" @oninput="OnDelayInput" />
            </div>
            <div>
                <label class="form-label">Audio volume: @Math.Round(AudioVolumePercent)%</label>
                <input type="range" min="0" max="100" value="@((int)Math.Round(AudioVolumePercent))" @oninput="OnVolumeInput" />
                <div class="text-muted small">Starts muted until changed</div>
            </div>
            <div>
                <label class="form-label">Columns: @TiledCols (max @Math.Max(ColsMax, TiledCols))</label>
                <input type="range" min="1" max="@Math.Max(ColsMax, TiledCols)" value="@TiledCols" @oninput="OnColsInput" />
                <div class="text-muted small">Grid: @Cols x @Rows</div>
            </div>
            <div>
                <label class="form-label">Min scale: @string.Format("{0:P0}", MinScale)</label>
                <input type="range" min="10" max="100" value="@((int)(MinScale*100))" @oninput="OnMinScaleInput" />
            </div>
            <div>
                <label class="form-label">Max scale: @string.Format("{0:P0}", MaxScale)</label>
                <input type="range" min="10" max="100" value="@((int)(MaxScale*100))" @oninput="OnMaxScaleInput" />
            </div>
            <div>
                <label class="form-label">Min tile width: @MinTilePx px</label>
                <input type="range" min="64" max="512" value="@MinTilePx" @oninput="OnMinTileInput" />
            </div>
            <div>
                <label class="form-label">Scale calculate retry: @RandomScaleTries</label>
                <input type="range" min="1" max="500" value="@RandomScaleTries" @oninput="OnRandomScaleTriesInput" />
            </div>
            <div class="buttons">
                <button class="btn btn-sm btn-outline-secondary" title="Toggle fullscreen" disabled="@IsWindowModeChanging" @onclick="ToggleWindowModeAsync">
                    @(IsFullScreen ? "Windowed View" : "Full Screen")
                </button>
                <button class="btn btn-sm btn-primary" @onclick="SaveAndApplyAsync">Save</button>
                <button class="btn btn-sm btn-secondary" @onclick="ChooseAndApplyFolderAsync">Change Folder</button>
                <button class="btn btn-sm btn-danger" @onclick="ExitApp">Exit</button>
            </div>
        </div>
    </div>
</div>

<div class="slideshow-container" @ref="ContainerRef">
    @foreach (var item in Items)
    {
        var style = $"left:{item.Left}px;top:{item.Top}px;width:{item.Width}px;height:{item.Height}px;";
        var imgStyle = $"width:{Math.Round(item.ImgWidth)}px;height:{Math.Round(item.ImgHeight)}px;";
        <div @key="item.Id" class="tile-item @(item.Removing ? "removing" : "")" style="@style">
            <img src="@item.Src" alt="img" style="@imgStyle" />
        </div>
    }

    <div id="clock-overlay" class="clock-overlay @(ClockOverlapped ? "dim" : "bright")">
        <div class="clock-time">@ClockTime</div>
        <div class="clock-date">@ClockDate</div>
    </div>
</div>
